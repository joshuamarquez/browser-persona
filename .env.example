# Copy to .env in project root for docker compose
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-mini
LLM_PROMPT_VERSION=v1
DEV_USER_ID=00000000-0000-0000-0000-000000000001
PIPELINE_IDLE_MS=90000
PIPELINE_INTERVAL_MS=60000
PIPELINE_AUTO_RUN=true
# Pattern mining: LLM adjudicates near-miss workflow pairs (requires OPENAI_API_KEY)
LLM_PATTERN_MERGE=true
LLM_PATTERN_MERGE_MAX_PAIRS=30
PATTERN_MIN_OCCURRENCES=3
INGEST_BODY_LIMIT_MB=25
VITE_API_BASE=http://localhost:3001
# Playwright execution
# - Host API (headful): npm run docker:exec  (db+web in Docker, API on your Mac)
# - Full Docker stack:  npm run docker:up    (headless only inside container)
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOW_MO=50
PLAYWRIGHT_TIMEOUT_MS=30000

# Copy to .env in project root for docker compose
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-mini
DEV_USER_ID=00000000-0000-0000-0000-000000000001
PIPELINE_IDLE_MS=90000
PIPELINE_INTERVAL_MS=60000
PIPELINE_AUTO_RUN=true
# Intent extraction (Phase 1): one LLM call per segmented workflow
INTENT_EXTRACT_AUTO=true
INTENT_EXTRACT_SKIP_NON_AUTOMATABLE=true
INTENT_PROMPT_VERSION=v1
# Intent execution (Phase 2)
INTENT_RUN_MAX_PLAN_CALLS_PER_TASK=3
INTENT_DOM_SNAPSHOT_MAX_CHARS=10000
# Intent dedup + auto-approve (Phase 3)
INTENT_AUTO_APPROVE_CONFIDENCE=0.85
INTENT_DEDUP_SIMILARITY_HIGH=0.92
INTENT_DEDUP_SIMILARITY_LOW=0.80
INTENT_DEDUP_LLM_CONFIRM=true
INTENT_AUTO_APPROVE_DOMAIN_BLOCKLIST=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Phase 4: data retention + extension semantic capture
RRWEB_RETENTION_DAYS=14
INGEST_BODY_LIMIT_MB=25
VITE_API_BASE=http://localhost:3001
# Playwright execution
# - Host API (headful): npm run docker:exec  (db+web in Docker, API on your Mac)
# - Full Docker stack:  npm run docker:up    (headless only inside container)
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOW_MO=50
PLAYWRIGHT_TIMEOUT_MS=30000

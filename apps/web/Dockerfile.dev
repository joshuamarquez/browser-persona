FROM node:22-alpine
WORKDIR /app

COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/

RUN npm install

COPY apps/web ./apps/web

ENV VITE_API_BASE=http://localhost:3001

EXPOSE 3000

CMD ["npm", "run", "dev", "-w", "@browser-persona/web", "--", "--host", "0.0.0.0", "--port", "3000"]

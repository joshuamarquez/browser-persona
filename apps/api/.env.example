DATABASE_URL=postgres://persona:persona@localhost:5432/browser_persona
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
PORT=3001
# rrweb batches include large DOM snapshots — default Fastify limit is 1MB
INGEST_BODY_LIMIT_MB=25
INTENT_PROMPT_VERSION=v1
# Dev only — replace with real auth
DEV_USER_ID=00000000-0000-0000-0000-000000000001
PIPELINE_IDLE_MS=90000
PIPELINE_INTERVAL_MS=60000
PIPELINE_AUTO_RUN=true
# Playwright execution (install browsers: npx playwright install chromium)
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOW_MO=50
PLAYWRIGHT_TIMEOUT_MS=30000
